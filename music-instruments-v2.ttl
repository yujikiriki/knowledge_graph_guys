@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix mi:        <http://mymusicalinstruments.org/> .
@prefix mi_fm:     <http://mymusicalinstruments.org/family/> .
@prefix mi_range:  <http://mymusicalinstruments.org/range/> .
@prefix mi_period: <http://mymusicalinstruments.org/period/> .
@prefix mi_region: <http://mymusicalinstruments.org/region/> .
@prefix mi_prod:   <http://mymusicalinstruments.org/production/> .
@prefix mi_scale:  <http://mymusicalinstruments.org/scale/> .
@prefix mi_genre:  <http://mymusicalinstruments.org/genre/> .

#################################################################
# ROOT SCHEME — scheme-of-schemes, holds no concepts directly
#################################################################

mi:musical-instruments a skos:ConceptScheme ;
  skos:prefLabel  "Musical instruments"@en ;
  skos:altLabel   "Musical instrument"@en ;
  skos:altLabel   "Instrumentos musicales"@es ;
  skos:altLabel   "Instrumento musical"@es ;
  skos:definition "Root scheme-of-schemes for the musical instruments vocabulary."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q34379> ;
  skos:scopeNote  "Navigate via mi:hasSubScheme to the seven axis schemes."@en ;
  mi:hasSubScheme
    mi:scheme-family ,
    mi:scheme-range ,
    mi:scheme-period ,
    mi:scheme-region ,
    mi:scheme-production ,
    mi:scheme-scale ,
    mi:scheme-genre
  .


#################################################################
# SCHEME 1 — FAMILY
# The only axis with a proper skos:broader/narrower hierarchy.
# All other axes are intentionally flat.
#################################################################

mi:scheme-family a skos:ConceptScheme ;
  skos:prefLabel   "Instrument families"@en ;
  skos:altLabel    "Familias de instrumentos"@es ;
  skos:definition  "Classifies instruments by organological family (L1-L4)."@en ;
  skos:hasTopConcept
    mi_fm:string-instruments ,
    mi_fm:wind-instruments ,
    mi_fm:percussion-instruments ,
    mi_fm:keyboard-instruments ,
    mi_fm:electronic-instruments
  .

# ── L1: Families ────────────────────────────────────────────────

mi_fm:string-instruments a skos:Concept ;
  skos:prefLabel    "String instruments"@en ;
  skos:altLabel     "Instrumentos de cuerda"@es ;
  skos:altLabel     "Chordophones"@en ;
  skos:definition   "Instruments producing tones by vibrating strings."@en ;
  skos:exactMatch   <http://www.wikidata.org/wiki/Q1798603> ;
  skos:topConceptOf mi:scheme-family ;
  skos:inScheme     mi:scheme-family ;
  skos:narrower
    mi_fm:bowed-string-instruments ,
    mi_fm:plucked-string-instruments
  .

mi_fm:wind-instruments a skos:Concept ;
  skos:prefLabel    "Wind instruments"@en ;
  skos:altLabel     "Instrumentos de viento"@es ;
  skos:altLabel     "Aerophones"@en ;
  skos:definition   "Instruments producing sound by vibration of air."@en ;
  skos:exactMatch   <http://www.wikidata.org/wiki/Q173453> ;
  skos:topConceptOf mi:scheme-family ;
  skos:inScheme     mi:scheme-family ;
  skos:narrower
    mi_fm:woodwind-instruments ,
    mi_fm:brass-instruments
  .

mi_fm:percussion-instruments a skos:Concept ;
  skos:prefLabel    "Percussion instruments"@en ;
  skos:altLabel     "Instrumentos de percusión"@es ;
  skos:definition   "Instruments producing sound by striking, shaking, or scraping."@en ;
  skos:exactMatch   <http://www.wikidata.org/wiki/Q133163> ;
  skos:topConceptOf mi:scheme-family ;
  skos:inScheme     mi:scheme-family ;
  skos:narrower
    mi_fm:membranophones ,
    mi_fm:idiophones
  .

mi_fm:keyboard-instruments a skos:Concept ;
  skos:prefLabel    "Keyboard instruments"@en ;
  skos:altLabel     "Instrumentos de teclado"@es ;
  skos:definition   "Instruments played via a keyboard triggering sound."@en ;
  skos:exactMatch   <http://www.wikidata.org/wiki/Q52954> ;
  skos:topConceptOf mi:scheme-family ;
  skos:inScheme     mi:scheme-family ;
  skos:narrower
    mi_fm:acoustic-keyboard-instruments ,
    mi_fm:electronic-keyboard-instruments
  .

mi_fm:electronic-instruments a skos:Concept ;
  skos:prefLabel    "Electronic instruments"@en ;
  skos:altLabel     "Instrumentos electrónicos"@es ;
  skos:definition   "Instruments generating or modifying sounds electronically."@en ;
  skos:exactMatch   <http://www.wikidata.org/wiki/Q1327500> ;
  skos:topConceptOf mi:scheme-family ;
  skos:inScheme     mi:scheme-family ;
  skos:narrower
    mi_fm:electronic-string-instruments
  .

# ── L2: Sub-families ────────────────────────────────────────────

mi_fm:bowed-string-instruments a skos:Concept ;
  skos:prefLabel  "Bowed string instruments"@en ;
  skos:altLabel   "Instrumentos de cuerda frotada"@es ;
  skos:definition "String instruments played by drawing a bow across strings."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q192096> ;
  skos:broader    mi_fm:string-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower   mi_fm:violin .

mi_fm:plucked-string-instruments a skos:Concept ;
  skos:prefLabel  "Plucked string instruments"@en ;
  skos:altLabel   "Instrumentos de cuerda pulsada"@es ;
  skos:definition "String instruments played by plucking with fingers or a plectrum."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q230262> ;
  skos:broader    mi_fm:string-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:guitar ,
    mi_fm:koto ,
    mi_fm:shamisen .

mi_fm:woodwind-instruments a skos:Concept ;
  skos:prefLabel  "Woodwind instruments"@en ;
  skos:altLabel   "Instrumentos de viento-madera"@es ;
  skos:definition "Wind instruments using split air streams or reeds."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q181247> ;
  skos:broader    mi_fm:wind-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:flute ,
    mi_fm:clarinet
  .

mi_fm:brass-instruments a skos:Concept ;
  skos:prefLabel  "Brass instruments"@en ;
  skos:altLabel   "Instrumentos de viento-metal"@es ;
  skos:definition "Wind instruments producing sound by lip vibration in a mouthpiece."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q180744> ;
  skos:broader    mi_fm:wind-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower   mi_fm:trumpet .

mi_fm:membranophones a skos:Concept ;
  skos:prefLabel  "Membranophones"@en ;
  skos:altLabel   "Membranófonos"@es ;
  skos:definition "Percussion instruments producing sound by a vibrating membrane."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q212892> ;
  skos:broader    mi_fm:percussion-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower   mi_fm:snare-drum .

mi_fm:idiophones a skos:Concept ;
  skos:prefLabel  "Idiophones"@en ;
  skos:altLabel   "Idiófonos"@es ;
  skos:definition "Percussion instruments producing sound from the body itself."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q12639> ;
  skos:broader    mi_fm:percussion-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:marimba ,
    mi_fm:cymbal
  .

mi_fm:acoustic-keyboard-instruments a skos:Concept ;
  skos:prefLabel  "Acoustic keyboard instruments"@en ;
  skos:altLabel   "Instrumentos de teclado acústicos"@es ;
  skos:definition "Keyboard instruments with acoustic sound production."@en ;
  skos:broader    mi_fm:keyboard-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:piano ,
    mi_fm:organ
  .

mi_fm:electronic-keyboard-instruments a skos:Concept ;
  skos:prefLabel  "Electronic keyboard instruments"@en ;
  skos:altLabel   "Instrumentos de teclado electrónicos"@es ;
  skos:definition "Keyboard instruments with electronic sound generation."@en ;
  skos:broader    mi_fm:keyboard-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower   mi_fm:synthesizer .

mi_fm:electronic-string-instruments a skos:Concept ;
  skos:prefLabel  "Electronic string instruments"@en ;
  skos:altLabel   "Instrumentos de cuerda electrónicos"@es ;
  skos:definition "String instruments using electronics for primary amplification."@en ;
  skos:broader    mi_fm:electronic-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower   mi_fm:electric-guitar .

# ── L3: Instruments ─────────────────────────────────────────────

mi_fm:violin a skos:Concept ;
  skos:prefLabel  "Violin"@en ;
  skos:altLabel   "Violín"@es ;
  skos:altLabel   "Fiddle"@en ;
  skos:definition "A bowed string instrument with four strings tuned in fifths."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q8355> ;
  skos:broader    mi_fm:bowed-string-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:baroque-violin ,
    mi_fm:electric-violin ,
    mi_fm:five-string-violin
  .

mi_fm:guitar a skos:Concept ;
  skos:prefLabel  "Guitar"@en ;
  skos:altLabel   "Guitarra"@es ;
  skos:definition "A fretted string instrument played by strumming or plucking."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q6607> ;
  skos:broader    mi_fm:plucked-string-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:classical-guitar ,
    mi_fm:steel-string-acoustic-guitar ,
    mi_fm:electric-guitar
  .

mi_fm:koto a skos:Concept ;
  skos:prefLabel  "Koto"@en ;
  skos:altLabel   "箏"@ja ;
  skos:altLabel   "Koto"@es ;
  skos:definition "A Japanese 13-string plucked instrument with movable bridges."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q201600> ;
  skos:broader    mi_fm:plucked-string-instruments ;
  skos:inScheme   mi:scheme-family .

mi_fm:shamisen a skos:Concept ;
  skos:prefLabel  "Shamisen"@en ;
  skos:altLabel   "三味線"@ja ;
  skos:altLabel   "Sangen"@en ;
  skos:altLabel   "Shamisen"@es ;
  skos:definition "A Japanese three-stringed plucked instrument played with a bachi."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q202538> ;
  skos:broader    mi_fm:plucked-string-instruments ;
  skos:inScheme   mi:scheme-family .

mi_fm:flute a skos:Concept ;
  skos:prefLabel  "Flute"@en ;
  skos:altLabel   "Flauta"@es ;
  skos:definition "A woodwind producing sound from air flow across an opening."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q11405> ;
  skos:broader    mi_fm:woodwind-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:concert-flute ,
    mi_fm:alto-flute ,
    mi_fm:piccolo
  .

mi_fm:clarinet a skos:Concept ;
  skos:prefLabel  "Clarinet"@en ;
  skos:altLabel   "Clarinete"@es ;
  skos:definition "A woodwind producing sound using a single reed mouthpiece."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q8343> ;
  skos:broader    mi_fm:woodwind-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:b-flat-clarinet ,
    mi_fm:a-clarinet ,
    mi_fm:bass-clarinet
  .

mi_fm:trumpet a skos:Concept ;
  skos:prefLabel  "Trumpet"@en ;
  skos:altLabel   "Trompeta"@es ;
  skos:definition "A brass instrument played with valves and a cup mouthpiece."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q8338> ;
  skos:broader    mi_fm:brass-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:b-flat-trumpet ,
    mi_fm:c-trumpet ,
    mi_fm:piccolo-trumpet
  .

mi_fm:snare-drum a skos:Concept ;
  skos:prefLabel  "Snare drum"@en ;
  skos:altLabel   "Caja"@es ;
  skos:altLabel   "Tarola"@es ;
  skos:definition "A drum with snares producing a sharp rattling timbre."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q208421> ;
  skos:broader    mi_fm:membranophones ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:orchestral-snare-drum ,
    mi_fm:marching-snare-drum ,
    mi_fm:piccolo-snare-drum
  .

mi_fm:marimba a skos:Concept ;
  skos:prefLabel  "Marimba"@en ;
  skos:altLabel   "Marimba"@es ;
  skos:definition "A pitched percussion instrument with wooden bars and resonators."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q220971> ;
  skos:broader    mi_fm:idiophones ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:four-octave-marimba ,
    mi_fm:five-octave-marimba ,
    mi_fm:concert-marimba
  .

mi_fm:cymbal a skos:Concept ;
  skos:prefLabel  "Cymbal"@en ;
  skos:altLabel   "Platillo"@es ;
  skos:definition "A percussion instrument of thin, round metal plate."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q190172> ;
  skos:broader    mi_fm:idiophones ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:crash-cymbal ,
    mi_fm:ride-cymbal ,
    mi_fm:hi-hat-cymbals
  .

mi_fm:piano a skos:Concept ;
  skos:prefLabel  "Piano"@en ;
  skos:altLabel   "Piano"@es ;
  skos:altLabel   "Pianoforte"@en ;
  skos:definition "An acoustic keyboard where hammers strike strings via keys."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q5994> ;
  skos:broader    mi_fm:acoustic-keyboard-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:grand-piano ,
    mi_fm:upright-piano ,
    mi_fm:prepared-piano
  .

mi_fm:organ a skos:Concept ;
  skos:prefLabel  "Organ"@en ;
  skos:altLabel   "Órgano"@es ;
  skos:definition "A keyboard instrument using pipes or electronic tone generation."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q1444> ;
  skos:broader    mi_fm:acoustic-keyboard-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:pipe-organ ,
    mi_fm:reed-organ ,
    mi_fm:hammond-organ
  .

mi_fm:synthesizer a skos:Concept ;
  skos:prefLabel  "Synthesizer"@en ;
  skos:altLabel   "Sintetizador"@es ;
  skos:altLabel   "Synth"@en ;
  skos:definition "An electronic instrument producing sounds via synthesis."@en ;
  skos:exactMatch <http://www.wikidata.org/wiki/Q163829> ;
  skos:broader    mi_fm:electronic-keyboard-instruments ;
  skos:inScheme   mi:scheme-family ;
  skos:narrower
    mi_fm:analog-synthesizer ,
    mi_fm:fm-synthesizer ,
    mi_fm:wavetable-synthesizer
  .

# electric-guitar: polyhierarchy — broader is both guitar (plucked) and
# electronic-string-instruments. Valid in SKOS.
mi_fm:electric-guitar a skos:Concept ;
  skos:prefLabel  "Electric guitar"@en ;
  skos:altLabel   "Guitarra eléctrica"@es ;
  skos:definition "A guitar using pickups and amplification."@en ;
  skos:broader
    mi_fm:guitar ,
    mi_fm:electronic-string-instruments ;
  skos:inScheme   mi:scheme-family .

# ── L4: Variants ────────────────────────────────────────────────

# Violin variants
mi_fm:baroque-violin a skos:Concept ;
  skos:prefLabel  "Baroque violin"@en ;
  skos:altLabel   "Violín barroco"@es ;
  skos:definition "A violin in Baroque setup with gut strings."@en ;
  skos:broader    mi_fm:violin ;
  skos:inScheme   mi:scheme-family .

mi_fm:electric-violin a skos:Concept ;
  skos:prefLabel  "Electric violin"@en ;
  skos:altLabel   "Violín eléctrico"@es ;
  skos:definition "A violin designed for electronic amplification via pickups."@en ;
  skos:broader    mi_fm:violin ;
  skos:inScheme   mi:scheme-family .

mi_fm:five-string-violin a skos:Concept ;
  skos:prefLabel  "Five-string violin"@en ;
  skos:altLabel   "Violín de cinco cuerdas"@es ;
  skos:definition "A violin variant with five strings, adding a lower C string."@en ;
  skos:broader    mi_fm:violin ;
  skos:inScheme   mi:scheme-family .

# Guitar variants
mi_fm:classical-guitar a skos:Concept ;
  skos:prefLabel  "Classical guitar"@en ;
  skos:altLabel   "Guitarra clásica"@es ;
  skos:definition "A guitar with nylon strings and a wider neck."@en ;
  skos:broader    mi_fm:guitar ;
  skos:inScheme   mi:scheme-family .

mi_fm:steel-string-acoustic-guitar a skos:Concept ;
  skos:prefLabel  "Steel-string acoustic guitar"@en ;
  skos:altLabel   "Guitarra acústica de cuerdas de acero"@es ;
  skos:definition "An acoustic guitar using steel strings for folk and pop styles."@en ;
  skos:broader    mi_fm:guitar ;
  skos:inScheme   mi:scheme-family .

# Flute variants
mi_fm:concert-flute a skos:Concept ;
  skos:prefLabel  "Concert flute"@en ;
  skos:altLabel   "Flauta travesera de concierto"@es ;
  skos:definition "The standard Western transverse flute for orchestras."@en ;
  skos:broader    mi_fm:flute ;
  skos:inScheme   mi:scheme-family .

mi_fm:alto-flute a skos:Concept ;
  skos:prefLabel  "Alto flute"@en ;
  skos:altLabel   "Flauta alto"@es ;
  skos:definition "A larger, lower-pitched member of the flute family."@en ;
  skos:broader    mi_fm:flute ;
  skos:inScheme   mi:scheme-family .

mi_fm:piccolo a skos:Concept ;
  skos:prefLabel  "Piccolo"@en ;
  skos:altLabel   "Flautín"@es ;
  skos:definition "A small flute sounding an octave above the concert flute."@en ;
  skos:broader    mi_fm:flute ;
  skos:inScheme   mi:scheme-family .

# Clarinet variants
mi_fm:b-flat-clarinet a skos:Concept ;
  skos:prefLabel  "B♭ clarinet"@en ;
  skos:altLabel   "Clarinete en Si♭"@es ;
  skos:definition "The most common clarinet, pitched in B♭."@en ;
  skos:broader    mi_fm:clarinet ;
  skos:inScheme   mi:scheme-family .

mi_fm:a-clarinet a skos:Concept ;
  skos:prefLabel  "A clarinet"@en ;
  skos:altLabel   "Clarinete en La"@es ;
  skos:definition "A clarinet pitched in A, used in orchestral repertoire."@en ;
  skos:broader    mi_fm:clarinet ;
  skos:inScheme   mi:scheme-family .

mi_fm:bass-clarinet a skos:Concept ;
  skos:prefLabel  "Bass clarinet"@en ;
  skos:altLabel   "Clarinete bajo"@es ;
  skos:definition "A large clarinet sounding an octave below the B♭ clarinet."@en ;
  skos:broader    mi_fm:clarinet ;
  skos:inScheme   mi:scheme-family .

# Trumpet variants
mi_fm:b-flat-trumpet a skos:Concept ;
  skos:prefLabel  "B♭ trumpet"@en ;
  skos:altLabel   "Trompeta en Si♭"@es ;
  skos:definition "The most common orchestral and band trumpet, pitched in B♭."@en ;
  skos:broader    mi_fm:trumpet ;
  skos:inScheme   mi:scheme-family .

mi_fm:c-trumpet a skos:Concept ;
  skos:prefLabel  "C trumpet"@en ;
  skos:altLabel   "Trompeta en Do"@es ;
  skos:definition "A trumpet pitched in C with a brighter orchestral tone."@en ;
  skos:broader    mi_fm:trumpet ;
  skos:inScheme   mi:scheme-family .

mi_fm:piccolo-trumpet a skos:Concept ;
  skos:prefLabel  "Piccolo trumpet"@en ;
  skos:altLabel   "Trompeta piccolo"@es ;
  skos:definition "A small, high-pitched trumpet in B♭ or A, an octave above."@en ;
  skos:broader    mi_fm:trumpet ;
  skos:inScheme   mi:scheme-family .

# Snare drum variants
mi_fm:orchestral-snare-drum a skos:Concept ;
  skos:prefLabel  "Orchestral snare drum"@en ;
  skos:altLabel   "Caja orquestal"@es ;
  skos:definition "A snare drum optimised for orchestral use."@en ;
  skos:broader    mi_fm:snare-drum ;
  skos:inScheme   mi:scheme-family .

mi_fm:marching-snare-drum a skos:Concept ;
  skos:prefLabel  "Marching snare drum"@en ;
  skos:altLabel   "Caja de marcha"@es ;
  skos:definition "A high-tension snare drum for marching ensembles."@en ;
  skos:broader    mi_fm:snare-drum ;
  skos:inScheme   mi:scheme-family .

mi_fm:piccolo-snare-drum a skos:Concept ;
  skos:prefLabel  "Piccolo snare drum"@en ;
  skos:altLabel   "Caja piccolo"@es ;
  skos:definition "A shallow snare drum producing a high, crisp sound."@en ;
  skos:broader    mi_fm:snare-drum ;
  skos:inScheme   mi:scheme-family .

# Marimba variants
mi_fm:four-octave-marimba a skos:Concept ;
  skos:prefLabel  "Four-octave marimba"@en ;
  skos:altLabel   "Marimba de cuatro octavas"@es ;
  skos:definition "A marimba spanning four octaves for educational settings."@en ;
  skos:broader    mi_fm:marimba ;
  skos:inScheme   mi:scheme-family .

mi_fm:five-octave-marimba a skos:Concept ;
  skos:prefLabel  "Five-octave marimba"@en ;
  skos:altLabel   "Marimba de cinco octavas"@es ;
  skos:definition "A concert marimba with five-octave range."@en ;
  skos:broader    mi_fm:marimba ;
  skos:inScheme   mi:scheme-family .

mi_fm:concert-marimba a skos:Concept ;
  skos:prefLabel  "Concert marimba"@en ;
  skos:altLabel   "Marimba de concierto"@es ;
  skos:definition "A professional-grade marimba for concert performance."@en ;
  skos:broader    mi_fm:marimba ;
  skos:inScheme   mi:scheme-family .

# Cymbal variants
mi_fm:crash-cymbal a skos:Concept ;
  skos:prefLabel  "Crash cymbal"@en ;
  skos:altLabel   "Platillo crash"@es ;
  skos:definition "A cymbal struck for a loud, quick-decaying accent."@en ;
  skos:broader    mi_fm:cymbal ;
  skos:inScheme   mi:scheme-family .

mi_fm:ride-cymbal a skos:Concept ;
  skos:prefLabel  "Ride cymbal"@en ;
  skos:altLabel   "Platillo ride"@es ;
  skos:definition "A large cymbal for maintaining a steady rhythmic pattern."@en ;
  skos:broader    mi_fm:cymbal ;
  skos:inScheme   mi:scheme-family .

mi_fm:hi-hat-cymbals a skos:Concept ;
  skos:prefLabel  "Hi-hat cymbals"@en ;
  skos:altLabel   "Platillos hi-hat"@es ;
  skos:definition "A pair of cymbals on a stand operated by foot pedal."@en ;
  skos:broader    mi_fm:cymbal ;
  skos:inScheme   mi:scheme-family .

# Piano variants
mi_fm:grand-piano a skos:Concept ;
  skos:prefLabel  "Grand piano"@en ;
  skos:altLabel   "Piano de cola"@es ;
  skos:definition "A piano with a horizontal, harp-shaped frame."@en ;
  skos:broader    mi_fm:piano ;
  skos:inScheme   mi:scheme-family .

mi_fm:upright-piano a skos:Concept ;
  skos:prefLabel  "Upright piano"@en ;
  skos:altLabel   "Piano vertical"@es ;
  skos:definition "A piano with a vertical frame for domestic use."@en ;
  skos:broader    mi_fm:piano ;
  skos:inScheme   mi:scheme-family .

mi_fm:prepared-piano a skos:Concept ;
  skos:prefLabel  "Prepared piano"@en ;
  skos:altLabel   "Piano preparado"@es ;
  skos:definition "A piano with objects placed on or between the strings."@en ;
  skos:broader    mi_fm:piano ;
  skos:inScheme   mi:scheme-family .

# Organ variants
mi_fm:pipe-organ a skos:Concept ;
  skos:prefLabel  "Pipe organ"@en ;
  skos:altLabel   "Órgano de tubos"@es ;
  skos:definition "An organ producing sound via pressurised air through pipes."@en ;
  skos:broader    mi_fm:organ ;
  skos:inScheme   mi:scheme-family .

mi_fm:reed-organ a skos:Concept ;
  skos:prefLabel  "Reed organ"@en ;
  skos:altLabel   "Órgano de lengüetas"@es ;
  skos:definition "An organ using air flowing over free metal reeds."@en ;
  skos:broader    mi_fm:organ ;
  skos:inScheme   mi:scheme-family .

mi_fm:hammond-organ a skos:Concept ;
  skos:prefLabel  "Hammond organ"@en ;
  skos:altLabel   "Órgano Hammond"@es ;
  skos:definition "An electromechanical organ using rotating tonewheels."@en ;
  skos:broader    mi_fm:organ ;
  skos:inScheme   mi:scheme-family .

# Synthesizer variants
mi_fm:analog-synthesizer a skos:Concept ;
  skos:prefLabel  "Analog synthesizer"@en ;
  skos:altLabel   "Sintetizador analógico"@es ;
  skos:definition "A synthesizer using analogue circuits: VCO, VCF, VCA."@en ;
  skos:broader    mi_fm:synthesizer ;
  skos:inScheme   mi:scheme-family .

mi_fm:fm-synthesizer a skos:Concept ;
  skos:prefLabel  "FM synthesizer"@en ;
  skos:altLabel   "Sintetizador FM"@es ;
  skos:definition "A synthesizer using frequency modulation of carrier waves."@en ;
  skos:broader    mi_fm:synthesizer ;
  skos:inScheme   mi:scheme-family .

mi_fm:wavetable-synthesizer a skos:Concept ;
  skos:prefLabel  "Wavetable synthesizer"@en ;
  skos:altLabel   "Sintetizador de tabla de ondas"@es ;
  skos:definition "A synthesizer reading through stored digital waveform tables."@en ;
  skos:broader    mi_fm:synthesizer ;
  skos:inScheme   mi:scheme-family .


#################################################################
# SCHEME 2 — RANGE
# Flat — no hierarchy among values.
#################################################################

mi:scheme-range a skos:ConceptScheme ;
  skos:prefLabel   "Register / range"@en ;
  skos:altLabel    "Registro"@es ;
  skos:definition  "Classifies instruments by their primary sounding register."@en ;
  skos:hasTopConcept
    mi_range:soprano ,
    mi_range:mezzo-soprano ,
    mi_range:alto ,
    mi_range:tenor ,
    mi_range:bass ,
    mi_range:wide-range ,
    mi_range:unpitched
  .

mi_range:soprano a skos:Concept ;
  skos:prefLabel    "Soprano"@en ;
  skos:altLabel     "Soprano"@es ;
  skos:definition   "Approximately C5 and above."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .

mi_range:mezzo-soprano a skos:Concept ;
  skos:prefLabel    "Mezzo-soprano"@en ;
  skos:altLabel     "Mezzo-soprano"@es ;
  skos:definition   "Approximately A4 to C6."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .

mi_range:alto a skos:Concept ;
  skos:prefLabel    "Alto"@en ;
  skos:altLabel     "Alto"@es ;
  skos:definition   "Approximately E3 to F5."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .

mi_range:tenor a skos:Concept ;
  skos:prefLabel    "Tenor"@en ;
  skos:altLabel     "Tenor"@es ;
  skos:definition   "Approximately C2 to C5."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .

mi_range:bass a skos:Concept ;
  skos:prefLabel    "Bass"@en ;
  skos:altLabel     "Bajo"@es ;
  skos:definition   "Approximately C1 to E3."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .

mi_range:wide-range a skos:Concept ;
  skos:prefLabel    "Wide range"@en ;
  skos:altLabel     "Rango amplio"@es ;
  skos:definition   "Spanning three or more octaves, not a single register."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .

mi_range:unpitched a skos:Concept ;
  skos:prefLabel    "Unpitched"@en ;
  skos:altLabel     "Sin altura definida"@es ;
  skos:definition   "Sound of indefinite or non-discrete pitch."@en ;
  skos:topConceptOf mi:scheme-range ;
  skos:inScheme     mi:scheme-range .


#################################################################
# SCHEME 3 — PERIOD
# Flat — chronologically ordered but no skos:broader.
#################################################################

mi:scheme-period a skos:ConceptScheme ;
  skos:prefLabel   "Historical period"@en ;
  skos:altLabel    "Período histórico"@es ;
  skos:definition  "Classifies instruments by the period of their canonical emergence."@en ;
  skos:hasTopConcept
    mi_period:ancient ,
    mi_period:medieval ,
    mi_period:renaissance ,
    mi_period:baroque ,
    mi_period:classical-era ,
    mi_period:romantic ,
    mi_period:modern ,
    mi_period:contemporary
  .

mi_period:ancient a skos:Concept ;
  skos:prefLabel    "Ancient"@en ;
  skos:altLabel     "Antiguo"@es ;
  skos:definition   "Originated in antiquity (before c. 500 CE)."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:medieval a skos:Concept ;
  skos:prefLabel    "Medieval"@en ;
  skos:altLabel     "Medieval"@es ;
  skos:definition   "Emerged during the medieval period (c. 500-1400)."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:renaissance a skos:Concept ;
  skos:prefLabel    "Renaissance"@en ;
  skos:altLabel     "Renacimiento"@es ;
  skos:definition   "Emerged or codified during the Renaissance (c. 1400-1600)."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:baroque a skos:Concept ;
  skos:prefLabel    "Baroque"@en ;
  skos:altLabel     "Barroco"@es ;
  skos:definition   "Primary during the Baroque era (c. 1600-1750)."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:classical-era a skos:Concept ;
  skos:prefLabel    "Classical era"@en ;
  skos:altLabel     "Período clásico"@es ;
  skos:definition   "Established during the Classical era (c. 1750-1820)."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:romantic a skos:Concept ;
  skos:prefLabel    "Romantic"@en ;
  skos:altLabel     "Romántico"@es ;
  skos:definition   "Established during the Romantic era (c. 1820-1900)."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:modern a skos:Concept ;
  skos:prefLabel    "Modern"@en ;
  skos:altLabel     "Moderno"@es ;
  skos:definition   "Widespread adoption roughly 1900-1945."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .

mi_period:contemporary a skos:Concept ;
  skos:prefLabel    "Contemporary"@en ;
  skos:altLabel     "Contemporáneo"@es ;
  skos:definition   "Invented or canonical form established after 1945."@en ;
  skos:topConceptOf mi:scheme-period ;
  skos:inScheme     mi:scheme-period .


#################################################################
# SCHEME 4 — REGION
# Flat — cultural/geographic traditions.
#################################################################

mi:scheme-region a skos:ConceptScheme ;
  skos:prefLabel   "Cultural / geographic region"@en ;
  skos:altLabel    "Región cultural / geográfica"@es ;
  skos:definition  "Classifies instruments by cultural or geographic tradition."@en ;
  skos:hasTopConcept
    mi_region:western-art-music ,
    mi_region:latin-american ,
    mi_region:african ,
    mi_region:east-asian ,
    mi_region:pan-cultural
  .

mi_region:western-art-music a skos:Concept ;
  skos:prefLabel    "Western art music"@en ;
  skos:altLabel     "Música artística occidental"@es ;
  skos:definition   "Central to European classical music and concert practice."@en ;
  skos:topConceptOf mi:scheme-region ;
  skos:inScheme     mi:scheme-region .

mi_region:latin-american a skos:Concept ;
  skos:prefLabel    "Latin American"@en ;
  skos:altLabel     "Latinoamericano"@es ;
  skos:definition   "Significant origin in Latin American traditions."@en ;
  skos:topConceptOf mi:scheme-region ;
  skos:inScheme     mi:scheme-region .

mi_region:african a skos:Concept ;
  skos:prefLabel    "African"@en ;
  skos:altLabel     "Africano"@es ;
  skos:definition   "Significant origin in African musical traditions."@en ;
  skos:topConceptOf mi:scheme-region ;
  skos:inScheme     mi:scheme-region .

mi_region:east-asian a skos:Concept ;
  skos:prefLabel    "East Asian"@en ;
  skos:altLabel     "Asia oriental"@es ;
  skos:definition   "Significant origin in East Asian musical traditions."@en ;
  skos:topConceptOf mi:scheme-region ;
  skos:inScheme     mi:scheme-region .

mi_region:pan-cultural a skos:Concept ;
  skos:prefLabel    "Pan-cultural"@en ;
  skos:altLabel     "Transcultural"@es ;
  skos:definition   "Not identified with a single tradition, adopted globally."@en ;
  skos:topConceptOf mi:scheme-region ;
  skos:inScheme     mi:scheme-region .


#################################################################
# SCHEME 5 — PRODUCTION MECHANISM
# Flat — fine-grained organological mechanism.
#################################################################

mi:scheme-production a skos:ConceptScheme ;
  skos:prefLabel   "Sound production mechanism"@en ;
  skos:altLabel    "Mecanismo de producción sonora"@es ;
  skos:definition  "Classifies instruments by physical sound-generation mechanism."@en ;
  skos:hasTopConcept
    mi_prod:bowed-string ,
    mi_prod:plucked-string ,
    mi_prod:struck-string ,
    mi_prod:edge-tone ,
    mi_prod:single-reed ,
    mi_prod:lip-reed ,
    mi_prod:struck-membrane ,
    mi_prod:struck-bar ,
    mi_prod:pipe-air-column ,
    mi_prod:free-reed ,
    mi_prod:tonewheel-em ,
    mi_prod:electromagnetic-pickup ,
    mi_prod:voltage-controlled ,
    mi_prod:fm-synthesis ,
    mi_prod:wavetable-playback
  .

mi_prod:bowed-string a skos:Concept ;
  skos:prefLabel    "Bowed string"@en ;
  skos:altLabel     "Cuerda frotada"@es ;
  skos:definition   "Sound from drawing a resined bow across strings."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:plucked-string a skos:Concept ;
  skos:prefLabel    "Plucked string"@en ;
  skos:altLabel     "Cuerda pulsada"@es ;
  skos:definition   "Sound from displacing a string with fingers or plectrum."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:struck-string a skos:Concept ;
  skos:prefLabel    "Struck string"@en ;
  skos:altLabel     "Cuerda percutida"@es ;
  skos:definition   "Sound from a hammer striking a string."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:edge-tone a skos:Concept ;
  skos:prefLabel    "Edge tone"@en ;
  skos:altLabel     "Bisel"@es ;
  skos:definition   "Sound from splitting an air stream across a sharp edge."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:single-reed a skos:Concept ;
  skos:prefLabel    "Single reed"@en ;
  skos:altLabel     "Lengüeta simple"@es ;
  skos:definition   "Sound from a single reed beating against a mouthpiece table."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:lip-reed a skos:Concept ;
  skos:prefLabel    "Lip reed"@en ;
  skos:altLabel     "Embocadura de labios"@es ;
  skos:definition   "Sound from the player's lips vibrating in a mouthpiece."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:struck-membrane a skos:Concept ;
  skos:prefLabel    "Struck membrane"@en ;
  skos:altLabel     "Membrana percutida"@es ;
  skos:definition   "Sound from striking a taut membrane."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:struck-bar a skos:Concept ;
  skos:prefLabel    "Struck bar / plate"@en ;
  skos:altLabel     "Barra o placa percutida"@es ;
  skos:definition   "Sound from striking a solid bar, plate, or disc."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:pipe-air-column a skos:Concept ;
  skos:prefLabel    "Pipe air-column resonance"@en ;
  skos:altLabel     "Resonancia en columna de aire"@es ;
  skos:definition   "Sound from air pressure exciting resonance in a pipe."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:free-reed a skos:Concept ;
  skos:prefLabel    "Free reed"@en ;
  skos:altLabel     "Lengüeta libre"@es ;
  skos:definition   "Sound from a metal tongue vibrating freely through a frame."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:tonewheel-em a skos:Concept ;
  skos:prefLabel    "Tonewheel electromechanical"@en ;
  skos:altLabel     "Rueda de tono electromecánica"@es ;
  skos:definition   "Sound from rotating tonewheels inducing alternating current."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:electromagnetic-pickup a skos:Concept ;
  skos:prefLabel    "Electromagnetic pickup"@en ;
  skos:altLabel     "Pastilla electromagnética"@es ;
  skos:definition   "Sound from a vibrating string disturbing a pickup coil."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:voltage-controlled a skos:Concept ;
  skos:prefLabel    "Voltage-controlled analogue synthesis"@en ;
  skos:altLabel     "Síntesis analógica por voltaje"@es ;
  skos:definition   "Sound generated by analogue circuits: VCO, VCF, and VCA."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:fm-synthesis a skos:Concept ;
  skos:prefLabel    "Frequency modulation synthesis"@en ;
  skos:altLabel     "Síntesis por modulación de frecuencia"@es ;
  skos:definition   "Sound from modulating the frequency of a carrier wave."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .

mi_prod:wavetable-playback a skos:Concept ;
  skos:prefLabel    "Wavetable playback"@en ;
  skos:altLabel     "Reproducción de tabla de ondas"@es ;
  skos:definition   "Sound from reading through stored digital waveform tables."@en ;
  skos:topConceptOf mi:scheme-production ;
  skos:inScheme     mi:scheme-production .


#################################################################
# SCHEME 6 — SCALE / TUNING SYSTEM  [NEW]
# Flat — no skos:broader/narrower hierarchy.
# Modal relationships via skos:related and mi:modeOf.
# Cross-cultural equivalences via skos:closeMatch.
#################################################################

mi:scheme-scale a skos:ConceptScheme ;
  skos:prefLabel   "Musical scales and tuning systems"@en ;
  skos:altLabel    "Escalas y sistemas de afinación"@es ;
  skos:definition  "Classifies scales, modes, and tuning systems for instruments."@en ;
  skos:hasTopConcept
    mi_scale:hirajoshi ,
    mi_scale:iwato ,
    mi_scale:insen ,
    mi_scale:akebono ,
    mi_scale:ritsu ,
    mi_scale:ryo ,
    mi_scale:hanryo-hanritsu ,
    mi_scale:in-scale ,
    mi_scale:yo-scale ,
    mi_scale:gagaku-scale ,
    mi_scale:minyo ,
    mi_scale:revati ,
    mi_scale:bairagi-bhairav
  .

# ── Japanese koto/shamisen tunings ─────────────────────────────

mi_scale:hirajoshi a skos:Concept ;
  skos:prefLabel    "Hirajōshi"@en ;
  skos:altLabel     "Hira-choshi"@en ;
  skos:altLabel     "平調子"@ja ;
  skos:altLabel     "Hirajōshi"@es ;
  skos:definition   "Hemitonic pentatonic koto tuning (2-1-4-1-4 semitones)."@en ;
  skos:exactMatch   <http://www.wikidata.org/wiki/Q3136035> ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:iwato ,
                    mi_scale:insen ;
  mi:hasIntervalPattern "2-1-4-1-4" ;
  mi:scaleCardinality  5 ;
  mi:isHemitonic       true .

mi_scale:iwato a skos:Concept ;
  skos:prefLabel    "Iwato"@en ;
  skos:altLabel     "Iwato"@es ;
  skos:definition   "Pentatonic koto scale (1 b2 4 b5 b7), a mode of Hirajoshi."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:hirajoshi ;
  mi:modeOf         mi_scale:hirajoshi ;
  mi:hasIntervalPattern "1-4-1-4-2" ;
  mi:scaleCardinality  5 ;
  mi:isHemitonic       true .

mi_scale:insen a skos:Concept ;
  skos:prefLabel    "Insen"@en ;
  skos:altLabel     "In Sen"@en ;
  skos:altLabel     "陰旋"@ja ;
  skos:altLabel     "いんせん"@ja ;
  skos:altLabel     "Insen"@es ;
  skos:definition   "Pentatonic koto tuning differing from Hirajoshi by one note."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:hirajoshi ;
  skos:closeMatch   mi_scale:revati ,
                    mi_scale:bairagi-bhairav ;
  mi:hasIntervalPattern "1-4-2-3-2" ;
  mi:scaleCardinality  5 ;
  mi:isHemitonic       true .

mi_scale:akebono a skos:Concept ;
  skos:prefLabel    "Akebono"@en ;
  skos:altLabel     "Akebono"@es ;
  skos:definition   "Diatonic-interval scale with no fixed tonic, classified as te."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale .

# ── Buddhist chant scales (shōmyō) ────────────────────────────

mi_scale:ritsu a skos:Concept ;
  skos:prefLabel    "Ritsu"@en ;
  skos:altLabel     "律"@ja ;
  skos:altLabel     "Ritsu"@es ;
  skos:definition   "Anhemitonic pentatonic scale (M2-m3-M2-M2-m3) for shomyo."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:ryo ,
                    mi_scale:hanryo-hanritsu ;
  mi:hasIntervalPattern "2-3-2-2-3" ;
  mi:scaleCardinality  5 ;
  mi:isHemitonic       false .

mi_scale:ryo a skos:Concept ;
  skos:prefLabel    "Ryo"@en ;
  skos:altLabel     "呂"@ja ;
  skos:altLabel     "Ryo"@es ;
  skos:definition   "Anhemitonic pentatonic scale (M2-M2-m3-M2-m3) for shomyo."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:ritsu ,
                    mi_scale:hanryo-hanritsu ;
  mi:hasIntervalPattern "2-2-3-2-3" ;
  mi:scaleCardinality  5 ;
  mi:isHemitonic       false .

mi_scale:hanryo-hanritsu a skos:Concept ;
  skos:prefLabel    "Hanryo hanritsu"@en ;
  skos:altLabel     "半呂半律"@ja ;
  skos:altLabel     "Hanryo hanritsu"@es ;
  skos:definition   "Hybrid of ritsu and ryo; no agreed combination method."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:ritsu ,
                    mi_scale:ryo .

# ── Scholarly scales (Uehara Rokushiro, late 1800s) ────────────

mi_scale:in-scale a skos:Concept ;
  skos:prefLabel    "In scale"@en ;
  skos:altLabel     "In scale"@es ;
  skos:definition   "Scale coined by Uehara Rokushiro using H-W-H-W-H pattern."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:yo-scale ,
                    mi_scale:iwato ;
  mi:isHemitonic    true .

mi_scale:yo-scale a skos:Concept ;
  skos:prefLabel    "Yo scale"@en ;
  skos:altLabel     "Yo scale"@es ;
  skos:definition   "Counterpart to In scale with three sharped degrees."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:in-scale ;
  mi:isHemitonic    true .

# ── Historical/court scale ─────────────────────────────────────

mi_scale:gagaku-scale a skos:Concept ;
  skos:prefLabel    "Gagaku scale"@en ;
  skos:altLabel     "Gagaku scale"@es ;
  skos:definition   "Heptatonic scale from 12 chromatic tones assembled by fifths."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  mi:scaleCardinality  7 ;
  mi:isHemitonic       true .

# ── Folk scale ─────────────────────────────────────────────────

mi_scale:minyo a skos:Concept ;
  skos:prefLabel    "Minyo scale"@en ;
  skos:altLabel     "Minyo"@es ;
  skos:definition   "Five-note scale without semitones (M2-m3-M2-m3) for folk."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:related      mi_scale:ritsu ;
  mi:hasIntervalPattern "2-3-2-3-2" ;
  mi:scaleCardinality  5 ;
  mi:isHemitonic       false .

# ── Cross-cultural equivalents (Indian ragas) ──────────────────

mi_scale:revati a skos:Concept ;
  skos:prefLabel    "Revati"@en ;
  skos:altLabel     "Revati"@es ;
  skos:definition   "Carnatic raga equivalent to the Japanese Insen scale."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:closeMatch   mi_scale:insen .

mi_scale:bairagi-bhairav a skos:Concept ;
  skos:prefLabel    "Bairagi Bhairav"@en ;
  skos:altLabel     "Bairagi Bhairav"@es ;
  skos:definition   "Hindustani raga equivalent to the Japanese Insen scale."@en ;
  skos:topConceptOf mi:scheme-scale ;
  skos:inScheme     mi:scheme-scale ;
  skos:closeMatch   mi_scale:insen .


#################################################################
# SCHEME 7 — GENRE  [NEW]
# Flat — music genres and traditions.
#################################################################

mi:scheme-genre a skos:ConceptScheme ;
  skos:prefLabel   "Music genres"@en ;
  skos:altLabel    "Géneros musicales"@es ;
  skos:definition  "Classifies genres and traditions in which instruments are used."@en ;
  skos:hasTopConcept
    mi_genre:gagaku ,
    mi_genre:shomyo ,
    mi_genre:jazz ,
    mi_genre:rock ,
    mi_genre:folk ,
    mi_genre:classical
  .

mi_genre:gagaku a skos:Concept ;
  skos:prefLabel    "Gagaku"@en ;
  skos:altLabel     "雅楽"@ja ;
  skos:altLabel     "Gagaku"@es ;
  skos:definition   "Japanese imperial court music, introduced from China."@en ;
  skos:topConceptOf mi:scheme-genre ;
  skos:inScheme     mi:scheme-genre ;
  mi:introducedFrom mi_region:east-asian .

mi_genre:shomyo a skos:Concept ;
  skos:prefLabel    "Shōmyō"@en ;
  skos:altLabel     "声明"@ja ;
  skos:altLabel     "Shōmyō"@es ;
  skos:definition   "Japanese Buddhist liturgical chant using ritsu and ryo scales."@en ;
  skos:topConceptOf mi:scheme-genre ;
  skos:inScheme     mi:scheme-genre .

mi_genre:jazz a skos:Concept ;
  skos:prefLabel    "Jazz"@en ;
  skos:altLabel     "Jazz"@es ;
  skos:definition   "Improvisational genre from African-American communities."@en ;
  skos:topConceptOf mi:scheme-genre ;
  skos:inScheme     mi:scheme-genre .

mi_genre:rock a skos:Concept ;
  skos:prefLabel    "Rock"@en ;
  skos:altLabel     "Rock"@es ;
  skos:definition   "Popular-music genre built on electric guitar, bass, and drums."@en ;
  skos:topConceptOf mi:scheme-genre ;
  skos:inScheme     mi:scheme-genre .

mi_genre:folk a skos:Concept ;
  skos:prefLabel    "Folk music"@en ;
  skos:altLabel     "Minyo"@en ;
  skos:altLabel     "Música folclórica"@es ;
  skos:definition   "Traditional community-based music passed by oral tradition."@en ;
  skos:topConceptOf mi:scheme-genre ;
  skos:inScheme     mi:scheme-genre .

mi_genre:classical a skos:Concept ;
  skos:prefLabel    "Western classical music"@en ;
  skos:altLabel     "Música clásica occidental"@es ;
  skos:definition   "Art music rooted in European traditions from c. 11th century."@en ;
  skos:topConceptOf mi:scheme-genre ;
  skos:inScheme     mi:scheme-genre .


