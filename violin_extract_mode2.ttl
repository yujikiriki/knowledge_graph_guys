# ===============================================================
# Tunings / Scales (SKOS Concepts)
# ===============================================================


tuning:standard-gdae a skos:Concept ;
    skos:prefLabel "Standard tuning G-D-A-E"@en ;
    rdfs:comment "Standard violin tuning in perfect fifths: G3-D4-A4-E5."@en ;
    prov:wasDerivedFrom _:prov038 .


tuning:south-indian a skos:Concept ;
    skos:prefLabel "South Indian tuning D#-A#-D#-A#"@en ;
    rdfs:comment "Sa-Pa-Sa-Pa tuning used in South Indian (Carnatic) violin."@en ;
    prov:wasDerivedFrom _:prov039 .


tuning:north-indian-hindustani a skos:Concept ;
    skos:prefLabel "North Indian Hindustani tuning Pa-Sa-Pa-Sa"@en ;
    rdfs:comment "Pa-Sa-Pa-Sa tuning, e.g. F-Bb-F-Bb, used in Hindustani violin."@en ;
    prov:wasDerivedFrom _:prov040 .


tuning:arabic-gdgd a skos:Concept ;
    skos:prefLabel "Arabic tuning G-D-G-D"@en ;
    rdfs:comment "A and E strings lowered a whole step to ease playing Arabic maqams."@en ;
    prov:wasDerivedFrom _:prov041 .


tuning:scordatura a skos:Concept ;
    skos:prefLabel "Scordatura"@en ;
    rdfs:comment "Non-standard tuning used for special musical effects."@en ;
    prov:wasDerivedFrom _:prov042 .


tuning:cross-tuning a skos:Concept ;
    skos:prefLabel "Cross tuning"@en ;
    rdfs:comment "Non-standard tuning used in folk styles."@en ;
    prov:wasDerivedFrom _:prov043 .


# ===============================================================
# Instrument Instances
# ===============================================================


instrument:violin a mi:BowedStringInstrument ;
    rdfs:label "Violin"@en ;
    rdfs:comment "Smallest, highest-pitched member of the violin family; a wooden chordophone."@en ;
    mi:hasProduction mi:acoustic-sound ;
    mi:madeOf material:spruce-and-maple ,
              material:spruce ,
              material:maple ,
              material:ebony ;
    mi:hasScale tuning:standard-gdae ;
    mi:hasGenre genre:classical ,
                genre:folk ,
                genre:country ,
                genre:bluegrass ,
                genre:jazz ,
                genre:indian-classical ,
                genre:iranian-classical ,
                genre:arabic-classical ,
                genre:popular ,
                genre:baroque ;
    prov:wasDerivedFrom _:prov044 , _:prov045 , _:prov046 , _:prov047 ,
                        _:prov048 , _:prov049 , _:prov050 , _:prov051 ;
    prov:wasGeneratedBy <urn:extraction:violin-wikipedia-mode2> .


