# ===============================================================
# Provenance — Extraction Activity
# ===============================================================

<urn:extraction:violin-wikipedia-mode2> a prov:Activity ;
    rdfs:label "Mode 2 extraction from Wikipedia Violin article"@en ;
    prov:used <https://en.wikipedia.org/wiki/Violin> ;
    prov:wasAssociatedWith <urn:agent:claude-data-extractor> .

<https://en.wikipedia.org/wiki/Violin> a prov:Entity ;
    rdfs:label "Wikipedia - Violin"@en .


# ===============================================================
# Sound Mechanisms
# ===============================================================


mechanism:piezoelectric-pickup a mi:ElectricSound ;
    rdfs:label "Piezoelectric pickup"@en ;
    rdfs:comment "Converts string vibration to an electric signal."@en ;
    prov:wasDerivedFrom _:prov001 .


mechanism:magnetic-pickup a mi:ElectricSound ;
    rdfs:label "Magnetic pickup"@en ;
    rdfs:comment "Magnetic device that converts string vibration to an electric signal."@en ;
    prov:wasDerivedFrom _:prov002 .


# ===============================================================
# Body Materials
# ===============================================================


material:spruce a mi:BodyMaterial ;
    rdfs:label "Spruce"@en ;
    rdfs:comment "Softwood used for violin soundboards (top plates)."@en ;
    prov:wasDerivedFrom _:prov003 .


material:norway-spruce a mi:BodyMaterial ;
    rdfs:label "Norway spruce"@en ;
    rdfs:comment "Picea abies; the preferred species for violin tops."@en ;
    prov:wasDerivedFrom _:prov004 .


material:maple a mi:BodyMaterial ;
    rdfs:label "Maple"@en ;
    rdfs:comment "Hardwood used for violin ribs, back, neck, and bridge."@en ;
    prov:wasDerivedFrom _:prov005 .


material:ebony a mi:BodyMaterial ;
    rdfs:label "Ebony"@en ;
    rdfs:comment "Dense hardwood used for fingerboards due to hardness and wear resistance."@en ;
    prov:wasDerivedFrom _:prov006 .


material:gut a mi:BodyMaterial ;
    rdfs:label "Gut"@en ;
    rdfs:comment "Animal intestine material historically used for violin strings."@en ;
    prov:wasDerivedFrom _:prov007 .


material:catgut a mi:BodyMaterial ;
    rdfs:label "Catgut"@en ;
    rdfs:comment "Common name for gut strings (not actually from cats)."@en ;
    prov:wasDerivedFrom _:prov008 .


material:perlon a mi:BodyMaterial ;
    rdfs:label "Perlon"@en ;
    rdfs:comment "Synthetic material used for modern violin strings."@en ;
    prov:wasDerivedFrom _:prov009 .


material:steel a mi:BodyMaterial ;
    rdfs:label "Steel"@en ;
    rdfs:comment "Metal used for modern violin strings."@en ;
    prov:wasDerivedFrom _:prov010 .


material:silver a mi:BodyMaterial ;
    rdfs:label "Silver"@en ;
    rdfs:comment "Precious metal sometimes used for string plating and bow windings."@en ;
    prov:wasDerivedFrom _:prov011 .


material:horsehair a mi:BodyMaterial ;
    rdfs:label "Horsehair"@en ;
    rdfs:comment "Hair from horse tail, used for violin bow hair."@en ;
    prov:wasDerivedFrom _:prov012 .


material:snakewood a mi:BodyMaterial ;
    rdfs:label "Snakewood"@en ;
    rdfs:comment "Dense tropical wood used for high-quality bow sticks."@en ;
    prov:wasDerivedFrom _:prov013 .


material:brazilwood a mi:BodyMaterial ;
    rdfs:label "Brazilwood"@en ;
    rdfs:comment "Tropical wood used for bow sticks, also known as Pernambuco wood."@en ;
    prov:wasDerivedFrom _:prov014 .


material:pernambuco-wood a mi:BodyMaterial ;
    rdfs:label "Pernambuco wood"@en ;
    rdfs:comment "Premium bow stick material, same species as brazilwood."@en ;
    prov:wasDerivedFrom _:prov015 .


material:carbon-fiber a mi:BodyMaterial ;
    rdfs:label "Carbon fiber"@en ;
    rdfs:comment "Modern composite material used for bow sticks."@en ;
    prov:wasDerivedFrom _:prov016 .


material:fiberglass a mi:BodyMaterial ;
    rdfs:label "Fiberglass"@en ;
    rdfs:comment "Inexpensive composite used for student bow sticks."@en ;
    prov:wasDerivedFrom _:prov017 .


material:rosin a mi:BodyMaterial ;
    rdfs:label "Rosin"@en ;
    rdfs:comment "Solid tree resin rubbed on bow hair to increase friction."@en ;
    prov:wasDerivedFrom _:prov018 .


material:animal-hide-glue a mi:BodyMaterial ;
    rdfs:label "Animal hide glue"@en ;
    rdfs:comment "Traditional adhesive used in violin construction joints."@en ;
    prov:wasDerivedFrom _:prov019 .


material:wood a mi:BodyMaterial ;
    rdfs:label "Wood"@en ;
    rdfs:comment "General wood material for the violin body."@en ;
    prov:wasDerivedFrom _:prov020 .


material:spruce-and-maple a mi:BodyMaterial ;
    rdfs:label "Spruce and maple"@en ;
    rdfs:comment "Composite: spruce top with maple back and ribs — standard violin construction."@en ;
    prov:wasDerivedFrom _:prov021 , _:prov022 .


